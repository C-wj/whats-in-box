page {
  min-height: 100vh;
  background-color: #f3fcf0;
  background-image:
    radial-gradient(circle at 16% 8%, rgba(7, 193, 96, 0.2), transparent 32%),
    radial-gradient(circle at 88% 18%, rgba(118, 243, 234, 0.22), transparent 34%),
    radial-gradient(circle at 76% 84%, rgba(102, 255, 149, 0.18), transparent 38%),
    linear-gradient(145deg, #f8fff5 0%, #eef9ec 44%, #dff3ec 100%);
  color: #161d16;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
textarea,
button,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  color: inherit;
  font: inherit;
  line-height: inherit;
  text-align: inherit;
}

button::after {
  border: 0;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 0 32rpx 260rpx;
  background: transparent;
}

.page--plain {
  background: transparent;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 184rpx;
  margin: 0 -32rpx;
  padding-top: 88rpx;
  padding-right: 224rpx;
  padding-left: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 20rpx 46rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.topbar--center {
  justify-content: center;
  padding-left: 128rpx;
  padding-right: 224rpx;
}

.topbar__title {
  overflow: hidden;
  color: #006d33;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 48rpx;
  letter-spacing: -1rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topbar__title--dark {
  color: #161d16;
}

.topbar__sub {
  display: block;
  margin-top: 4rpx;
  color: rgba(61, 74, 61, 0.68);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.topbar__actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.icon-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  min-width: 56rpx;
  max-width: 56rpx;
  height: 56rpx;
  min-height: 56rpx;
  max-height: 56rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.64);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.34);
  color: #006d33;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(0, 109, 51, 0.08);
  -webkit-backdrop-filter: blur(20rpx);
  backdrop-filter: blur(20rpx);
}

.icon-btn--bell::before {
  position: absolute;
  width: 22rpx;
  height: 24rpx;
  border: 4rpx solid #006d33;
  border-bottom: 0;
  border-radius: 20rpx 20rpx 8rpx 8rpx;
  content: "";
}

.icon-btn--bell::after {
  position: absolute;
  bottom: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #006d33;
  content: "";
}

.icon-btn--gear::before {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border: 5rpx solid #006d33;
  border-radius: 999rpx;
  content: "";
}

.icon-btn--gear::after {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #006d33;
  box-shadow:
    0 -18rpx 0 #006d33,
    0 18rpx 0 #006d33,
    -18rpx 0 0 #006d33,
    18rpx 0 0 #006d33;
  content: "";
}

.header-spacer {
  height: 28rpx;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 92rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.44);
  color: #3d4a3d;
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #161d16;
  font-size: 26rpx;
  font-weight: 700;
}

.chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin-right: 16rpx;
  padding: 16rpx 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 40rpx;
  vertical-align: top;
  box-shadow: 0 10rpx 24rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.chip--active {
  border-color: rgba(7, 193, 96, 0.34);
  background: rgba(7, 193, 96, 0.18);
  color: #00471f;
  box-shadow: 0 14rpx 30rpx rgba(7, 193, 96, 0.18);
}

.section {
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  color: #161d16;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
  letter-spacing: -1rpx;
}

.section-action {
  color: #006d33;
  font-size: 24rpx;
  font-weight: 800;
}

.card,
.hero-card,
.soft-card,
.metric-card,
.item-row {
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.07);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
}

.hero-card::after {
  position: absolute;
  right: -60rpx;
  bottom: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  filter: blur(28rpx);
  content: "";
}

.hero-title {
  position: relative;
  color: #161d16;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 52rpx;
  letter-spacing: -1rpx;
}

.hero-desc {
  position: relative;
  margin-top: 12rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.soft-card {
  background: rgba(255, 255, 255, 0.34);
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c 0%, #07c160 48%, #006d33 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(7, 193, 96, 0.28);
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #006d33;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.danger-btn {
  border-color: rgba(186, 26, 26, 0.22);
  color: #ba1a1a;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.metric-card {
  min-height: 150rpx;
  padding: 26rpx;
}

.metric-value {
  color: #006d33;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.18);
}

.metric-label {
  margin-top: 8rpx;
  color: #6c7b6c;
  font-size: 24rpx;
  font-weight: 700;
}

.item-row {
  display: flex;
  gap: 24rpx;
  min-height: 164rpx;
  padding: 20rpx;
}

.thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.8), transparent 46%),
    linear-gradient(135deg, rgba(7, 193, 96, 0.22), rgba(118, 243, 234, 0.18));
  color: #006d33;
  font-size: 40rpx;
  font-weight: 900;
}

.thumb image {
  width: 100%;
  height: 100%;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  overflow: hidden;
  color: #161d16;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  margin-top: 8rpx;
  color: #3d4a3d;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #00471f;
  font-size: 22rpx;
  font-weight: 900;
}

.empty {
  padding: 42rpx 30rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.7);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.32);
  color: #6c7b6c;
  text-align: center;
  font-size: 26rpx;
  line-height: 40rpx;
  box-shadow: 0 18rpx 38rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.empty-title {
  margin-bottom: 10rpx;
  color: #161d16;
  font-size: 30rpx;
  font-weight: 900;
}

.bottom-nav {
  position: fixed;
  right: 32rpx;
  bottom: calc(22rpx + constant(safe-area-inset-bottom));
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  z-index: 60;
  display: flex;
  align-items: center;
  height: 112rpx;
  padding: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
  box-shadow: 0 26rpx 60rpx rgba(22, 29, 22, 0.13);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
}

.bottom-nav__item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  color: #3d4a3d;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.bottom-nav__item--active {
  border: 1rpx solid rgba(7, 193, 96, 0.26);
  background: linear-gradient(135deg, rgba(102, 255, 149, 0.34), rgba(7, 193, 96, 0.22));
  color: #00471f;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.26);
}

.bottom-nav__icon {
  display: block;
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 6rpx;
}

.bottom-nav__label {
  display: block;
  line-height: 28rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  margin: 0 0 12rpx 4rpx;
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.64);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 16rpx 34rpx rgba(22, 29, 22, 0.05);
  color: #161d16;
  font-size: 28rpx;
  font-weight: 700;
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.textarea {
  min-height: 180rpx;
  padding-top: 24rpx;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
