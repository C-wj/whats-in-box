.form-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 104rpx;
  margin: 0 -32rpx;
  padding: 28rpx 32rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.form-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 58rpx;
  font-weight: 300;
}

.form-back .app-icon {
  color: inherit;
}

.form-title {
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
}

.profile-preview-card,
.profile-form-card {
  margin-top: 28rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.34);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.profile-preview-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.9), transparent 42%),
    linear-gradient(135deg, rgba(102, 255, 149, 0.36), rgba(118, 243, 234, 0.3));
  color: #006d33;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(0, 109, 51, 0.14);
}

.preview-main {
  min-width: 0;
}

.preview-name {
  overflow: hidden;
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-meta {
  overflow: hidden;
  margin-top: 8rpx;
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-field {
  margin-top: 30rpx;
}

.box-field:first-child {
  margin-top: 0;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 8rpx 14rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
}

.optional {
  color: #6f7d70;
  font-weight: 700;
}

.box-input {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 16rpx 34rpx rgba(22, 29, 22, 0.05);
  color: #161d16;
  font-size: 28rpx;
  font-weight: 800;
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.footer-actions {
  position: sticky;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(243, 252, 240, 0), rgba(243, 252, 240, 0.92) 34%);
}
