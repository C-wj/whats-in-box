<view class="scan-page">
  <image class="scan-bg" src="/assets/images/image-13.jpg" mode="aspectFill" />
  <view class="scan-dim"></view>

  <view class="scan-topbar" style="{{nav.centerTopbarStyle}}">
    <view class="scan-back" bindtap="goHome">‹</view>
    <view class="scan-title">箱里有什么</view>
    <view class="scan-spacer"></view>
  </view>

  <view class="scanner-wrap">
    <view class="scanner-frame">
      <view class="scan-line"></view>
      <view class="corner corner--tl"></view>
      <view class="corner corner--tr"></view>
      <view class="corner corner--bl"></view>
      <view class="corner corner--br"></view>
    </view>

    <view class="scan-hint">扫描二维码或物品进行识别</view>

    <view class="scan-actions">
      <view class="scan-action {{flashOn ? 'scan-action--active' : ''}}" bindtap="toggleFlash">
        <view class="scan-action__icon">↯</view>
        <view class="scan-action__label">手电</view>
      </view>
      <view class="scan-action" bindtap="chooseFromAlbum">
        <view class="scan-action__icon">▧</view>
        <view class="scan-action__label">相册</view>
      </view>
      <view class="scan-action" bindtap="goManual">
        <view class="scan-action__icon">☰</view>
        <view class="scan-action__label">手动</view>
      </view>
    </view>
  </view>

  <view class="bottom-nav scan-bottom-nav">
    <view class="bottom-nav__item" bindtap="goHome">
      <image class="bottom-nav__icon" src="/assets/tab/home.svg" mode="aspectFit" />
      <text class="bottom-nav__label">首页</text>
    </view>
    <view class="bottom-nav__item bottom-nav__item--active">
      <image class="bottom-nav__icon" src="/assets/tab/scan-active.svg" mode="aspectFit" />
      <text class="bottom-nav__label">扫描</text>
    </view>
    <view class="bottom-nav__item" bindtap="goLocations">
      <image class="bottom-nav__icon" src="/assets/tab/stats.svg" mode="aspectFit" />
      <text class="bottom-nav__label">统计</text>
    </view>
    <view class="bottom-nav__item" bindtap="goSettings">
      <image class="bottom-nav__icon" src="/assets/tab/me.svg" mode="aspectFit" />
      <text class="bottom-nav__label">我的</text>
    </view>
  </view>
</view>
