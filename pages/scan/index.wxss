.scan-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 12%, rgba(7, 193, 96, 0.36), transparent 32%),
    radial-gradient(circle at 86% 18%, rgba(118, 243, 234, 0.24), transparent 34%),
    radial-gradient(circle at 76% 88%, rgba(69, 225, 124, 0.18), transparent 38%),
    linear-gradient(160deg, #111a18 0%, #293936 48%, #0b0f0e 100%);
}

.scan-bg {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(rgba(255, 255, 255, 0.04) 1rpx, transparent 1rpx);
  background-size: 96rpx 96rpx;
  opacity: 0.5;
}

.scan-dim {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.34);
}

.scan-topbar {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 32rpx;
  padding-left: 32rpx;
  color: #ffffff;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0));
  -webkit-backdrop-filter: blur(16rpx);
  backdrop-filter: blur(16rpx);
}

.scan-back,
.scan-spacer {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
}

.scan-back {
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.12);
  font-size: 58rpx;
  font-weight: 300;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.18);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.scan-title {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.scanner-wrap {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  flex-direction: column;
  min-height: calc(100vh - 112rpx);
  padding-top: 300rpx;
}

.scanner-frame {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.46);
  border-top-color: rgba(255, 255, 255, 0.72);
  border-left-color: rgba(255, 255, 255, 0.62);
  border-radius: 56rpx;
  background: rgba(255, 255, 255, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 28rpx 70rpx rgba(0, 0, 0, 0.24);
  overflow: hidden;
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.scanner-frame__tap {
  position: absolute;
  right: 0;
  bottom: 54rpx;
  left: 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.scan-line {
  position: absolute;
  top: 36rpx;
  right: 28rpx;
  left: 28rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #07c160, transparent);
  box-shadow: 0 0 34rpx #07c160;
  animation: scanLine 2.8s ease-in-out infinite;
}

.corner {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-color: #07c160;
  border-style: solid;
  border-width: 8rpx;
}

.corner--tl {
  top: -4rpx;
  left: -4rpx;
  border-right: 0;
  border-bottom: 0;
  border-top-left-radius: 40rpx;
}

.corner--tr {
  top: -4rpx;
  right: -4rpx;
  border-bottom: 0;
  border-left: 0;
  border-top-right-radius: 40rpx;
}

.corner--bl {
  bottom: -4rpx;
  left: -4rpx;
  border-top: 0;
  border-right: 0;
  border-bottom-left-radius: 40rpx;
}

.corner--br {
  right: -4rpx;
  bottom: -4rpx;
  border-top: 0;
  border-left: 0;
  border-bottom-right-radius: 40rpx;
}

.scan-hint {
  margin-top: 60rpx;
  padding: 18rpx 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.16);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.scan-actions {
  display: flex;
  gap: 110rpx;
  margin-top: 86rpx;
}

.scan-action {
  display: flex;
  align-items: center;
  flex-direction: column;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 800;
}

.scan-action__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 42rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.18);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.scan-bottom-nav {
  border-color: rgba(255, 255, 255, 0.36);
  background: rgba(255, 255, 255, 0.42);
}

@keyframes scanLine {
  0%,
  100% {
    top: 36rpx;
  }

  50% {
    top: 480rpx;
  }
}
