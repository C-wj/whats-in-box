.stats-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 260rpx;
  background: transparent;
}

.stats-filter {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
  white-space: nowrap;
}

.stats-chip {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 24rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.stats-chip--active {
  border-color: rgba(7, 193, 96, 0.34);
  background: rgba(7, 193, 96, 0.18);
  color: #00471f;
  box-shadow: 0 14rpx 30rpx rgba(7, 193, 96, 0.18);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.stats-card {
  min-height: 198rpx;
  padding: 32rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.07);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.stats-card__label {
  color: #3d4a3d;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.stats-card__value {
  margin-top: 28rpx;
  color: #006d33;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 64rpx;
  letter-spacing: -2rpx;
  text-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.18);
}

.stats-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 40rpx 0 22rpx;
}

.stats-section-title {
  color: #161d16;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 52rpx;
  letter-spacing: -1rpx;
}

.stats-section-action {
  padding-bottom: 6rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 700;
}

.distribution-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.distribution-card {
  min-height: 150rpx;
  padding: 28rpx 28rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.88);
  border-left-color: rgba(255, 255, 255, 0.78);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.distribution-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.distribution-name {
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.distribution-badge {
  min-width: 94rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.22);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.14);
  color: #007a3d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 32rpx;
  text-align: center;
}

.distribution-track {
  position: relative;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.44);
}

.distribution-fill {
  height: 100%;
  min-width: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #45e17c, #07c160);
  box-shadow: 0 0 20rpx rgba(7, 193, 96, 0.32);
}

.distribution-fill--blue {
  background: linear-gradient(90deg, #76f3ea, #0a84ff);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.26);
}

.location-head {
  align-items: flex-start;
}

.location-subtitle {
  margin-top: 8rpx;
  color: #6c7b6c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.location-add {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c, #07c160);
  color: #ffffff;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(7, 193, 96, 0.24);
}

.location-tree {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.location-row {
  padding: 22rpx 24rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.88);
  border-left-color: rgba(255, 255, 255, 0.78);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.location-row__main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.location-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 900;
}

.location-icon--box {
  background: rgba(7, 193, 96, 0.16);
}

.location-copy {
  flex: 1;
  min-width: 0;
}

.location-name {
  overflow: hidden;
  color: #161d16;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #6c7b6c;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-count {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 900;
}

.location-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 18rpx;
}

.location-action {
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 999rpx;
  background: rgba(0, 122, 61, 0.08);
  color: #007a3d;
  font-size: 23rpx;
  font-weight: 900;
}

.location-action--danger {
  background: rgba(186, 26, 26, 0.08);
  color: #ba1a1a;
}

.location-action--disabled {
  opacity: 0.36;
}

.location-empty {
  padding: 42rpx 30rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.7);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.32);
  color: #6c7b6c;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 18rpx 38rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.location-empty__title {
  margin-bottom: 10rpx;
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
}

.location-empty__btn {
  margin-top: 26rpx;
}
