.stats-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 260rpx;
  background: transparent;
}

.stats-filter {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
  white-space: nowrap;
}

.stats-chip {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 24rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.stats-chip--active {
  border-color: rgba(7, 193, 96, 0.34);
  background: rgba(7, 193, 96, 0.18);
  color: #00471f;
  box-shadow: 0 14rpx 30rpx rgba(7, 193, 96, 0.18);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.stats-card {
  min-height: 198rpx;
  padding: 32rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.07);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.stats-card__label {
  color: #3d4a3d;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.stats-card__value {
  margin-top: 28rpx;
  color: #006d33;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 64rpx;
  letter-spacing: -2rpx;
  text-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.18);
}

.stats-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 40rpx 0 22rpx;
}

.stats-section-title {
  color: #161d16;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 52rpx;
  letter-spacing: -1rpx;
}

.stats-section-action {
  padding-bottom: 6rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 700;
}

.distribution-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.distribution-card {
  min-height: 150rpx;
  padding: 28rpx 28rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.88);
  border-left-color: rgba(255, 255, 255, 0.78);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.distribution-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.distribution-name {
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.distribution-badge {
  min-width: 94rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.22);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.14);
  color: #007a3d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 32rpx;
  text-align: center;
}

.distribution-track {
  position: relative;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.44);
}

.distribution-fill {
  height: 100%;
  min-width: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #45e17c, #07c160);
  box-shadow: 0 0 20rpx rgba(7, 193, 96, 0.32);
}

.distribution-fill--blue {
  background: linear-gradient(90deg, #76f3ea, #0a84ff);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.26);
}

.location-head {
  align-items: flex-start;
}

.location-subtitle {
  margin-top: 8rpx;
  color: #6c7b6c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.location-add {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c, #07c160);
  color: #ffffff;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(7, 193, 96, 0.24);
}

.space-map {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 14rpx 0 0;
}

.space-map::before {
  position: absolute;
  top: 38rpx;
  bottom: 28rpx;
  left: 38rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(7, 193, 96, 0.32), rgba(255, 255, 255, 0.28));
  content: "";
}

.space-node {
  position: relative;
  min-width: 0;
}

.space-node__branch {
  position: absolute;
  top: 64rpx;
  left: -30rpx;
  width: 42rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.24);
}

.space-card {
  position: relative;
  padding-top: 12rpx;
}

.space-card__plane {
  position: absolute;
  top: 0;
  right: 34rpx;
  left: 34rpx;
  height: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx 28rpx 16rpx 16rpx;
  background: rgba(255, 255, 255, 0.34);
  box-shadow: 0 12rpx 28rpx rgba(22, 29, 22, 0.04);
  transform: skewX(-18deg);
}

.space-card__body {
  position: relative;
  overflow: hidden;
  min-height: 164rpx;
  padding: 24rpx 24rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.66);
  border-top-color: rgba(255, 255, 255, 0.94);
  border-left-color: rgba(255, 255, 255, 0.84);
  border-radius: 36rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.24)),
    rgba(255, 255, 255, 0.38);
  box-shadow:
    0 24rpx 52rpx rgba(22, 29, 22, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.space-card__body::after {
  position: absolute;
  right: -54rpx;
  bottom: -76rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.11);
  content: "";
}

.space-card--home .space-card__body {
  min-height: 184rpx;
  background:
    radial-gradient(circle at 82% 10%, rgba(102, 255, 149, 0.3), transparent 32%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.62), rgba(226, 255, 237, 0.38));
}

.space-card--room .space-card__body {
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.56), rgba(229, 249, 255, 0.24)),
    rgba(255, 255, 255, 0.36);
}

.space-card--cabinet .space-card__body,
.space-card--drawer .space-card__body {
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.54), rgba(255, 248, 231, 0.22)),
    rgba(255, 255, 255, 0.36);
}

.space-card--box .space-card__body {
  border-color: rgba(7, 193, 96, 0.22);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.52), rgba(218, 255, 231, 0.36)),
    rgba(255, 255, 255, 0.36);
}

.space-card__main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.space-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 78rpx;
  height: 78rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.64);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.92), transparent 44%),
    rgba(7, 193, 96, 0.13);
  color: #007832;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.space-card--room .space-icon {
  background: rgba(0, 88, 188, 0.08);
  color: #0058bc;
}

.space-card--cabinet .space-icon,
.space-card--drawer .space-icon {
  background: rgba(140, 80, 0, 0.08);
  color: #8c5000;
}

.space-copy {
  flex: 1;
  min-width: 0;
}

.space-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.space-name {
  overflow: hidden;
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.space-type {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.18);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.1);
  color: #007832;
  font-size: 20rpx;
  font-weight: 900;
}

.space-path,
.space-meta {
  overflow: hidden;
  color: #6c7b6c;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.space-path {
  margin-top: 8rpx;
  color: #3d4a3d;
}

.space-meta {
  margin-top: 4rpx;
}

.space-count {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 900;
}

.space-actions {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 20rpx;
}

.space-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 52rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 999rpx;
  background: rgba(0, 122, 61, 0.08);
  color: #007a3d;
  font-size: 22rpx;
  font-weight: 900;
}

.space-action--danger {
  border-color: rgba(186, 26, 26, 0.14);
  background: rgba(186, 26, 26, 0.08);
  color: #ba1a1a;
}

.space-action--disabled {
  opacity: 0.36;
}

.location-empty {
  padding: 42rpx 30rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.7);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.32);
  color: #6c7b6c;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 18rpx 38rpx rgba(22, 29, 22, 0.04);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.location-empty__title {
  margin-bottom: 10rpx;
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
}

.location-empty__btn {
  margin-top: 26rpx;
}
