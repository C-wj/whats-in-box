<view class="page stats-page" style="{{navPaddingStyle}}">
  <view class="stats-filter">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="stats-chip {{activeFilter === item.key ? 'stats-chip--active' : ''}}"
      bindtap="onFilterTap"
      data-key="{{item.key}}"
    >
      {{item.name}}
    </view>
  </view>

  <view class="stats-grid">
    <view class="stats-card" wx:for="{{cards}}" wx:key="label">
      <view class="stats-card__label">{{item.label}}</view>
      <view class="stats-card__value">{{item.value}}</view>
    </view>
  </view>

  <view class="stats-section-head">
    <view class="stats-section-title">位置分布</view>
    <view class="stats-section-action">按盒子数</view>
  </view>

  <view class="distribution-list">
    <view class="distribution-card" wx:for="{{distribution}}" wx:key="name">
      <view class="distribution-row">
        <view class="distribution-name">{{item.name}}</view>
        <view class="distribution-badge">{{item.count}} 盒</view>
      </view>
      <view class="distribution-track">
        <view
          class="distribution-fill {{item.isBlue ? 'distribution-fill--blue' : ''}}"
          style="width: {{item.percent}}%;"
        ></view>
      </view>
    </view>
  </view>

  <view class="stats-section-head location-head">
    <view>
      <view class="stats-section-title">位置管理</view>
      <view class="location-subtitle">管理家、房间、柜子、抽屉和盒子</view>
    </view>
    <view class="stats-section-action location-add" bindtap="goAddRootLocation">新增位置</view>
  </view>

  <view class="space-map" wx:if="{{locationRows.length}}">
    <view class="space-node" wx:for="{{locationRows}}" wx:key="id" style="margin-left: {{item.visualIndent}}rpx;">
      <view wx:if="{{item.depth > 1}}" class="space-node__branch"></view>
      <view class="space-card {{item.typeCardClass}}">
        <view class="space-card__plane"></view>
        <view class="space-card__body">
          <view class="space-card__main" bindtap="goLocationDetail" data-id="{{item.id}}" data-name="{{item.name}}" data-path="{{item.path}}">
            <view class="space-icon">
              <view class="app-icon {{item.typeIconClass}}"></view>
            </view>
            <view class="space-copy">
              <view class="space-name-row">
                <view class="space-name">{{item.name}}</view>
                <view class="space-type">{{item.typeLabel}}</view>
              </view>
              <view class="space-path" wx:if="{{item.pathText}}">{{item.pathText}}</view>
              <view class="space-meta">{{item.childCount || 0}} 个子级 · 第 {{item.visualLevel}} 层</view>
            </view>
            <view class="space-count">{{item.itemCount || 0}} 件</view>
          </view>
          <view class="space-actions">
            <view class="space-action {{item.canAddChild ? '' : 'space-action--disabled'}}" bindtap="goAddChildLocation" data-id="{{item.id}}" data-depth="{{item.depth}}">
              <view class="app-icon app-icon--add app-icon--sm"></view>
              <text>子级</text>
            </view>
            <view class="space-action" bindtap="goEditLocation" data-id="{{item.id}}">
              <view class="app-icon app-icon--edit app-icon--sm"></view>
              <text>编辑</text>
            </view>
            <view class="space-action space-action--danger" bindtap="deleteLocation" data-id="{{item.id}}">
              <view class="app-icon app-icon--delete app-icon--sm app-icon--danger"></view>
              <text>删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="location-empty" wx:elif="{{locationLoading}}">
    <view class="location-empty__title">正在加载位置</view>
    <view>请稍候。</view>
  </view>
  <view class="location-empty" wx:else>
    <view class="location-empty__title">还没有位置</view>
    <view>系统会自动创建“我的家”，也可以手动新增。</view>
    <button class="primary-btn location-empty__btn" bindtap="goAddRootLocation">新增位置</button>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav__item" bindtap="goHome">
      <image class="bottom-nav__icon" src="/assets/tab/home.svg" mode="aspectFit" />
      <text class="bottom-nav__label">首页</text>
    </view>
    <view class="bottom-nav__item" bindtap="goScan">
      <image class="bottom-nav__icon" src="/assets/tab/scan.svg" mode="aspectFit" />
      <text class="bottom-nav__label">扫描</text>
    </view>
    <view class="bottom-nav__item bottom-nav__item--active">
      <image class="bottom-nav__icon" src="/assets/tab/stats-active.svg" mode="aspectFit" />
      <text class="bottom-nav__label">统计</text>
    </view>
    <view class="bottom-nav__item" bindtap="goSettings">
      <image class="bottom-nav__icon" src="/assets/tab/me.svg" mode="aspectFit" />
      <text class="bottom-nav__label">我的</text>
    </view>
  </view>
</view>
