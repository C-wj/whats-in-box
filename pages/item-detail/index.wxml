<view class="item-detail-page">
  <view class="item-topbar" style="{{nav.centerTopbarStyle}}">
    <view class="item-back" bindtap="goBack">
      <view class="app-icon app-icon--back"></view>
    </view>
    <view class="item-top-title">物品详情</view>
    <view class="item-edit-icon" bindtap="editItem">
      <view class="app-icon app-icon--edit"></view>
    </view>
  </view>

  <view class="item-hero" style="{{heroOffsetStyle}}">
    <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" />
    <view wx:else class="item-hero__fallback">{{item.initial}}</view>
    <view class="image-actions">
      <view class="image-action">
        <view class="app-icon app-icon--place app-icon--muted"></view>
      </view>
      <view class="image-action">
        <view class="app-icon app-icon--photo app-icon--muted"></view>
      </view>
    </view>
  </view>

  <view class="item-info-card">
    <view class="item-info-head">
      <view class="item-detail-title">{{item.name}}</view>
      <view class="qty-pill">数量：{{item.quantity}}</view>
    </view>
    <view class="stored-line">
      <view class="app-icon app-icon--box app-icon--sm app-icon--muted"></view>
      <text>{{item.locationPath}}</text>
    </view>
    <view class="remarks-block">
      <view class="remarks-label">备注</view>
      <view class="remarks-copy">{{item.note || '暂无备注'}}</view>
    </view>
  </view>

  <view class="meta-grid">
    <view class="meta-card">
      <view class="meta-icon meta-icon--blue">
        <view class="app-icon app-icon--refresh app-icon--blue"></view>
      </view>
      <view class="meta-label">最近更新</view>
      <view class="meta-value">{{item.updatedLabel}}</view>
    </view>
    <view class="meta-card">
      <view class="meta-icon meta-icon--gold">
        <view class="app-icon app-icon--tag app-icon--gold"></view>
      </view>
      <view class="meta-label">标签</view>
      <view class="meta-value">{{item.tagsText || '暂无标签'}}</view>
    </view>
  </view>

  <picker mode="selector" range="{{locationNames}}" value="{{locationIndex}}" bindchange="onLocationChange">
    <view class="stored-card move-target-card {{canMove ? 'move-target-card--ready' : ''}}">
      <view class="stored-icon">
        <view class="app-icon app-icon--box app-icon--blue"></view>
      </view>
      <view class="stored-copy">
        <view class="meta-label">移动到</view>
        <view class="stored-title">{{selectedLocation.path || item.locationPath || '请选择位置'}}</view>
        <view class="stored-hint">{{canMove ? '点击下方按钮确认移动' : '点这里选择新的存放位置'}}</view>
      </view>
      <view class="stored-arrow app-icon app-icon--arrow app-icon--muted"></view>
    </view>
  </picker>

  <view class="bottom-actions">
    <button class="delete-btn" bindtap="deleteItem">
      <view class="app-icon app-icon--delete app-icon--danger"></view>
    </button>
    <button class="move-action {{canMove ? 'move-action--ready' : ''}}" bindtap="moveItem" loading="{{isMoving}}" disabled="{{isMoving}}">
      <view class="app-icon app-icon--move"></view>
      <text>确认移动</text>
    </button>
    <button class="edit-action" bindtap="editItem">
      <view class="app-icon app-icon--edit app-icon--light"></view>
      <text>编辑详情</text>
    </button>
  </view>
</view>
