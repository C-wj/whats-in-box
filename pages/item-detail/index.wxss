.item-detail-page {
  min-height: 100vh;
  padding-bottom: 188rpx;
  background: #f9f9f9;
}

.item-topbar {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 40;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 112rpx;
  padding: 36rpx 32rpx 0;
  background: rgba(249, 249, 249, 0.94);
}

.item-back,
.item-edit-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 56rpx;
  font-weight: 400;
}

.item-edit-icon {
  font-size: 44rpx;
}

.item-top-title {
  color: #111515;
  font-size: 32rpx;
  font-weight: 500;
}

.item-hero {
  position: relative;
  width: 100%;
  height: 820rpx;
  overflow: hidden;
  background: #eef2ee;
}

.item-hero image,
.item-hero__fallback {
  width: 100%;
  height: 100%;
}

.item-hero__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 120rpx;
  font-weight: 900;
}

.image-actions {
  position: absolute;
  right: 32rpx;
  bottom: 80rpx;
  display: flex;
  gap: 20rpx;
}

.image-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #3d4a3d;
  font-size: 34rpx;
  font-weight: 800;
}

.item-info-card,
.meta-card,
.stored-card {
  border: 1rpx solid #ededed;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.item-info-card {
  position: relative;
  z-index: 5;
  margin: -56rpx 32rpx 0;
  padding: 32rpx;
}

.item-info-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.item-detail-title {
  color: #111515;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 54rpx;
}

.qty-pill {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #007832;
  font-size: 24rpx;
  font-weight: 900;
}

.stored-line {
  margin-top: 22rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 800;
}

.remarks-block {
  margin-top: 30rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #ededed;
}

.remarks-label,
.meta-label {
  color: #6f7d70;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.remarks-copy {
  margin-top: 18rpx;
  color: #3d4a3d;
  font-size: 30rpx;
  line-height: 46rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin: 26rpx 32rpx 0;
}

.meta-card {
  min-height: 188rpx;
  padding: 30rpx;
}

.meta-icon {
  margin-bottom: 26rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.meta-icon--blue {
  color: #0058bc;
}

.meta-icon--gold {
  color: #8c5000;
}

.meta-value {
  margin-top: 8rpx;
  color: #111515;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.stored-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 142rpx;
  margin: 26rpx 32rpx 0;
  padding: 24rpx;
}

.stored-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 18rpx;
  background: rgba(0, 88, 188, 0.1);
  color: #0058bc;
  font-size: 42rpx;
  font-weight: 900;
}

.stored-copy {
  flex: 1;
  min-width: 0;
}

.stored-title {
  overflow: hidden;
  color: #111515;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stored-arrow {
  color: #6f7d70;
  font-size: 56rpx;
  font-weight: 500;
}

.move-target-card {
  border-color: rgba(0, 120, 50, 0.18);
}

.move-target-card--ready {
  border-color: rgba(0, 120, 50, 0.55);
  background: linear-gradient(135deg, #ffffff 0%, #f0fff5 100%);
}

.stored-hint {
  margin-top: 10rpx;
  color: #6f7d70;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #ededed;
  background: rgba(249, 249, 249, 0.94);
}

.delete-btn,
.move-action,
.edit-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.delete-btn {
  flex: 0 0 96rpx;
  border: 2rpx solid rgba(186, 26, 26, 0.22);
  color: #ba1a1a;
}

.move-action {
  flex: 1;
  border: 2rpx solid #007832;
  color: #007832;
}

.move-action--ready {
  background: rgba(7, 193, 96, 0.12);
}

.edit-action {
  flex: 1;
  background: #007832;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(0, 109, 51, 0.22);
}
