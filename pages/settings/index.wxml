<view class="page page--plain">
  <view class="topbar topbar--center" style="{{nav.centerTopbarStyle}}">
    <button class="nav-back" bindtap="goHome">
      <view class="app-icon app-icon--back"></view>
    </button>
    <view class="topbar__title topbar__title--dark">箱里有什么</view>
  </view>

  <view class="profile-head" bindtap="goProfileEdit">
    <view class="avatar-wrap">
      <view class="avatar">{{profile.avatarText}}</view>
      <view class="avatar-edit">
        <view class="app-icon app-icon--edit app-icon--light app-icon--sm"></view>
      </view>
    </view>
    <view class="profile-name">{{profile.profileName}}</view>
    <view class="profile-meta">{{profile.profileMeta}}</view>
  </view>

  <view class="total-card card">
    <view>
      <view class="stat-label">物品总数</view>
      <view class="total-value">{{stats.itemCount}}</view>
    </view>
    <view class="stat-icon">
      <view class="app-icon app-icon--item"></view>
    </view>
  </view>

  <view class="mini-grid">
    <view class="mini-card card" bindtap="goLocations">
      <view class="mini-icon mini-icon--orange">
        <view class="app-icon app-icon--box app-icon--gold"></view>
      </view>
      <view class="mini-value">{{stats.locationCount}}</view>
      <view class="mini-label">盒子总数</view>
    </view>
    <view class="mini-card card" bindtap="goLabels">
      <view class="mini-icon mini-icon--blue">
        <view class="app-icon app-icon--tag app-icon--blue"></view>
      </view>
      <view class="mini-value">{{stats.labelCount}}</view>
      <view class="mini-label">启用标签</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-heading">管理</view>
    <view class="menu-card card">
      <button class="menu-row" bindtap="goLocations">
        <view class="menu-icon app-icon app-icon--stats app-icon--muted"></view>
        <text class="menu-title">统计看板</text>
        <view class="menu-arrow app-icon app-icon--arrow app-icon--muted"></view>
      </button>
      <button class="menu-row" bindtap="exportData">
        <view class="menu-icon app-icon app-icon--box app-icon--muted"></view>
        <text class="menu-title">导出数据</text>
        <view class="menu-arrow app-icon app-icon--arrow app-icon--muted"></view>
      </button>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-heading">应用</view>
    <view class="menu-card card">
      <button class="menu-row" bindtap="checkHealth">
        <view class="menu-icon app-icon app-icon--settings app-icon--muted"></view>
        <text class="menu-title">服务状态 · {{serviceStatus}}</text>
        <view class="menu-arrow app-icon app-icon--arrow app-icon--muted"></view>
      </button>
      <button class="menu-row" bindtap="goAbout">
        <view class="menu-icon app-icon app-icon--info app-icon--muted"></view>
        <text class="menu-title">关于我们</text>
        <view class="menu-arrow app-icon app-icon--arrow app-icon--muted"></view>
      </button>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav__item" bindtap="goHome">
      <image class="bottom-nav__icon" src="/assets/tab/home.svg" mode="aspectFit" />
      <text class="bottom-nav__label">首页</text>
    </view>
    <view class="bottom-nav__item" bindtap="goScan">
      <image class="bottom-nav__icon" src="/assets/tab/scan.svg" mode="aspectFit" />
      <text class="bottom-nav__label">扫描</text>
    </view>
    <view class="bottom-nav__item" bindtap="goLocations">
      <image class="bottom-nav__icon" src="/assets/tab/stats.svg" mode="aspectFit" />
      <text class="bottom-nav__label">统计</text>
    </view>
    <view class="bottom-nav__item bottom-nav__item--active">
      <image class="bottom-nav__icon" src="/assets/tab/me-active.svg" mode="aspectFit" />
      <text class="bottom-nav__label">我的</text>
    </view>
  </view>
</view>
