.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 56rpx;
  color: #006d33;
  font-size: 52rpx;
  font-weight: 300;
}

.profile-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 42rpx;
  padding-bottom: 8rpx;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.9), transparent 42%),
    linear-gradient(135deg, rgba(102, 255, 149, 0.36), rgba(118, 243, 234, 0.3));
  color: #006d33;
  font-size: 48rpx;
  font-weight: 900;
  box-shadow: 0 20rpx 44rpx rgba(0, 109, 51, 0.16);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.avatar-edit {
  position: absolute;
  right: -8rpx;
  bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c, #006d33);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.profile-name {
  margin-top: 24rpx;
  color: #161d16;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.profile-meta {
  margin-top: 4rpx;
  color: #3d4a3d;
  font-size: 22rpx;
  font-weight: 600;
}

.total-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 44rpx;
  padding: 30rpx;
}

.stat-label {
  color: #3d4a3d;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.total-value {
  margin-top: 4rpx;
  color: #006d33;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.stat-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 24rpx;
  background: rgba(7, 193, 96, 0.14);
  color: #006d33;
  font-size: 36rpx;
  font-weight: 800;
}

.mini-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 20rpx;
}

.mini-card {
  min-height: 160rpx;
  padding: 26rpx;
}

.mini-icon {
  font-size: 28rpx;
  font-weight: 900;
}

.mini-icon--orange {
  color: #8c5000;
}

.mini-icon--blue {
  color: #0058bc;
}

.mini-value {
  margin-top: 26rpx;
  color: #161d16;
  font-size: 30rpx;
  font-weight: 900;
}

.mini-label {
  margin-top: 4rpx;
  color: #3d4a3d;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-section {
  margin-top: 36rpx;
}

.menu-section:last-of-type {
  margin-bottom: 32rpx;
}

.menu-heading {
  margin: 0 0 16rpx 4rpx;
  color: #6c7b6c;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.menu-card {
  overflow: hidden;
}

.menu-row {
  display: grid;
  grid-template-columns: 48rpx 1fr 32rpx;
  align-items: center;
  min-height: 96rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.32);
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-icon {
  color: #3d4a3d;
  font-size: 30rpx;
  font-weight: 800;
}

.menu-title {
  color: #161d16;
  font-size: 26rpx;
  font-weight: 800;
}

.menu-arrow {
  color: #161d16;
  font-size: 34rpx;
  text-align: right;
}

.sign-out {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 36rpx 0 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.44);
  color: #ba1a1a;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 34rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.sign-out--login {
  border-color: rgba(7, 193, 96, 0.26);
  background: linear-gradient(135deg, #45e17c, #006d33);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(7, 193, 96, 0.28);
}
