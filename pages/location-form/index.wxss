.form-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 104rpx;
  margin: 0 -32rpx;
  padding: 28rpx 32rpx 0;
  border-bottom: 1rpx solid #eeeeee;
  background: #f9f9f9;
}

.form-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 58rpx;
  font-weight: 300;
}

.form-title {
  color: #111515;
  font-size: 32rpx;
  font-weight: 900;
}

.location-form-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: #f3f5ee;
}

.box-field {
  margin-top: 30rpx;
}

.box-field:first-child {
  margin-top: 0;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 8rpx 14rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
}

.optional {
  color: #6f7d70;
  font-weight: 700;
}

.box-input,
.box-picker,
.tag-input-card {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  color: #111515;
  font-size: 28rpx;
  font-weight: 800;
}

.box-picker {
  justify-content: space-between;
}

.picker-pin {
  margin-right: 14rpx;
  color: #007832;
  font-size: 34rpx;
}

.picker-arrow {
  margin-left: auto;
  color: #a8bca9;
  font-size: 34rpx;
}

.tag-input-card {
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 108rpx;
  padding: 20rpx 28rpx;
}

.tag-input {
  flex: 1;
  min-width: 160rpx;
  height: 54rpx;
  font-size: 26rpx;
}

.cover-upload {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  height: 552rpx;
  margin-top: 34rpx;
  overflow: hidden;
  border: 4rpx dashed #bfd4bf;
  border-radius: 22rpx;
  background: #eeeeee;
  color: #3d4a3d;
}

.compact-cover {
  height: 360rpx;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

.cover-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  color: #07c160;
  font-size: 48rpx;
  font-weight: 900;
}

.cover-title {
  margin-top: 28rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 800;
}

.cover-sub {
  margin-top: 12rpx;
  color: #6f7d70;
  font-size: 26rpx;
  font-weight: 800;
}

.footer-actions {
  position: sticky;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(247, 248, 244, 0), #f7f8f4 24%);
}
