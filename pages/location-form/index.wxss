.form-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 104rpx;
  margin: 0 -32rpx;
  padding: 28rpx 32rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.form-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 58rpx;
  font-weight: 300;
}

.form-title {
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
}

.location-form-card {
  margin-top: 28rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.34);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.box-field {
  margin-top: 30rpx;
}

.box-field:first-child {
  margin-top: 0;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 8rpx 14rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
}

.optional {
  color: #6f7d70;
  font-weight: 700;
}

.box-input,
.box-picker,
.tag-input-card {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 16rpx 34rpx rgba(22, 29, 22, 0.05);
  color: #161d16;
  font-size: 28rpx;
  font-weight: 800;
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.box-picker {
  justify-content: space-between;
}

.picker-pin {
  margin-right: 14rpx;
  color: #007832;
  font-size: 34rpx;
}

.picker-arrow {
  margin-left: auto;
  color: #a8bca9;
  font-size: 34rpx;
}

.tag-input-card {
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 108rpx;
  padding: 20rpx 28rpx;
}

.tag-input {
  flex: 1;
  min-width: 160rpx;
  height: 54rpx;
  font-size: 26rpx;
}

.cover-upload {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  height: 552rpx;
  margin-top: 34rpx;
  overflow: hidden;
  border: 3rpx dashed rgba(255, 255, 255, 0.72);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.72), transparent 38%),
    rgba(255, 255, 255, 0.28);
  color: #3d4a3d;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.compact-cover {
  height: 360rpx;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

.cover-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  color: #07c160;
  font-size: 48rpx;
  font-weight: 900;
}

.cover-title {
  margin-top: 28rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 800;
}

.cover-sub {
  margin-top: 12rpx;
  color: #6f7d70;
  font-size: 26rpx;
  font-weight: 800;
}

.footer-actions {
  position: sticky;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(243, 252, 240, 0), rgba(243, 252, 240, 0.92) 34%);
}
