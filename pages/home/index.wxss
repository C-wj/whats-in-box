.search-icon {
  color: #3d4a3d;
  font-size: 32rpx;
  line-height: 1;
}

.chip-row-fixed {
  display: flex;
  flex-direction: row;
  width: 100%;
  margin-top: 24rpx;
  padding-bottom: 4rpx;
  overflow: hidden;
}

.box-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 28rpx;
}

.box-card {
  display: flex;
  min-height: 216rpx;
  gap: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.box-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 168rpx;
  height: 168rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ddc3a0, #f2eadf);
  color: #006d33;
  font-size: 42rpx;
  font-weight: 900;
}

.box-thumb image {
  width: 100%;
  height: 100%;
}

.box-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.box-title {
  overflow: hidden;
  color: #1a1c1c;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-location {
  margin-top: 8rpx;
  overflow: hidden;
  color: #3d4a3d;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.box-count {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(7, 193, 96, 0.16);
  color: #00471f;
  font-size: 24rpx;
  font-weight: 800;
}

.box-updated {
  overflow: hidden;
  color: rgba(61, 74, 61, 0.72);
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(144rpx + env(safe-area-inset-bottom));
  z-index: 70;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 112rpx;
  min-height: 112rpx;
  max-height: 112rpx;
  border-radius: 24rpx;
  background: #006d33;
  color: #ffffff;
  font-size: 54rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 32rpx rgba(0, 109, 51, 0.28);
}

.home-empty {
  margin-top: 40rpx;
}
