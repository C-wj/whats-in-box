.search-icon {
  width: 34rpx;
  height: 34rpx;
  color: #3d4a3d;
  font-size: 32rpx;
  line-height: 1;
}

.chip-row-fixed {
  display: flex;
  flex-direction: row;
  width: 100%;
  margin-top: 24rpx;
  padding-bottom: 4rpx;
  overflow: hidden;
}

.box-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 30rpx;
}

.box-card {
  display: flex;
  min-height: 216rpx;
  gap: 24rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.07);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.box-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 168rpx;
  height: 168rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 32% 20%, rgba(255, 255, 255, 0.86), transparent 44%),
    linear-gradient(135deg, rgba(7, 193, 96, 0.24), rgba(118, 243, 234, 0.22));
  color: #006d33;
  font-size: 42rpx;
  font-weight: 900;
}

.box-thumb image {
  width: 100%;
  height: 100%;
}

.box-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.box-title {
  overflow: hidden;
  color: #161d16;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  overflow: hidden;
  color: #3d4a3d;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-location text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.box-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.box-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.24);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.14);
  color: #00471f;
  font-size: 24rpx;
  font-weight: 900;
}

.box-updated {
  overflow: hidden;
  color: rgba(61, 74, 61, 0.72);
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(158rpx + env(safe-area-inset-bottom));
  z-index: 70;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 112rpx;
  min-height: 112rpx;
  max-height: 112rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c 0%, #07c160 48%, #006d33 100%);
  color: #ffffff;
  font-weight: 500;
  box-shadow: 0 22rpx 46rpx rgba(7, 193, 96, 0.34);
}

.home-empty {
  margin-top: 40rpx;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.main-item-list {
  margin-top: 30rpx;
}
