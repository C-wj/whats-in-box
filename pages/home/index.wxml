<view class="page">
  <view class="topbar" style="{{nav.topbarStyle}}">
    <view class="topbar__title">箱里有什么</view>
    <view class="topbar__actions">
      <view class="icon-btn icon-btn--bell"></view>
      <view class="icon-btn icon-btn--gear" bindtap="goSettings"></view>
    </view>
  </view>

  <view class="header-spacer"></view>

  <view class="search-shell" bindtap="goSearch">
    <view class="search-icon app-icon app-icon--search app-icon--muted"></view>
    <input
      class="search-input"
      placeholder="搜索盒子或物品..."
      confirm-type="search"
      value="{{query}}"
      bindinput="onQueryInput"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <view class="chip-row-fixed">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="chip {{item.key === activeFilterKey ? 'chip--active' : ''}}"
      bindtap="onFilterTap"
      data-key="{{item.key}}"
    >
      {{item.label}}
    </view>
  </view>

  <view class="item-list main-item-list" wx:if="{{isRecentMode && recentItems.length}}">
    <view class="item-row" wx:for="{{recentItems}}" wx:key="id" bindtap="goItemDetail" data-id="{{item.id}}">
      <view class="thumb">
        <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" />
        <text wx:else>{{item.initial}}</text>
      </view>
      <view class="item-main">
        <view class="item-title">{{item.name}}</view>
        <view class="item-meta">{{item.locationPath}}</view>
        <view class="item-meta">数量 {{item.quantity || 1}} · 更新 {{item.updatedLabel}}</view>
      </view>
    </view>
  </view>

  <view class="box-list" wx:elif="{{!isRecentMode && boxCards.length}}">
    <view
      class="box-card"
      wx:for="{{boxCards}}"
      wx:key="id"
      bindtap="goLocationDetail"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
      data-path="{{item.path}}"
    >
      <view class="box-thumb">
        <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" />
        <text wx:else>{{item.initial}}</text>
      </view>
      <view class="box-main">
        <view>
          <view class="box-title">{{item.name}}</view>
          <view class="box-location">
            <view class="app-icon app-icon--place app-icon--sm app-icon--muted"></view>
            <text>{{item.path}}</text>
          </view>
        </view>
        <view class="box-foot">
          <text class="box-count">{{item.itemCount || 0}} 件物品</text>
          <text class="box-updated">更新：{{item.updatedLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty home-empty" wx:else>
    <view class="empty-title">{{isRecentMode ? '还没有最近物品' : (allBoxCards.length ? '没有匹配的盒子' : '还没有盒子')}}</view>
    <view>{{isRecentMode ? '保存物品后会显示在这里。' : (allBoxCards.length ? '换个筛选条件试试。' : '可以先直接添加物品，之后再整理到盒子里。')}}</view>
  </view>

  <view class="home-fab" bindtap="goNewItem">
    <view class="app-icon app-icon--add app-icon--light app-icon--lg"></view>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav__item bottom-nav__item--active">
      <image class="bottom-nav__icon" src="/assets/tab/home-active.svg" mode="aspectFit" />
      <text class="bottom-nav__label">首页</text>
    </view>
    <view class="bottom-nav__item" bindtap="goScan">
      <image class="bottom-nav__icon" src="/assets/tab/scan.svg" mode="aspectFit" />
      <text class="bottom-nav__label">扫描</text>
    </view>
    <view class="bottom-nav__item" bindtap="goLocations">
      <image class="bottom-nav__icon" src="/assets/tab/stats.svg" mode="aspectFit" />
      <text class="bottom-nav__label">统计</text>
    </view>
    <view class="bottom-nav__item" bindtap="goSettings">
      <image class="bottom-nav__icon" src="/assets/tab/me.svg" mode="aspectFit" />
      <text class="bottom-nav__label">我的</text>
    </view>
  </view>
</view>
