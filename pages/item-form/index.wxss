.form-card {
  margin-top: 12rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: #f3f5ee;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.image-cell,
.image-add {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 190rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.05);
}

.image-cell image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.48);
  color: #ffffff;
  font-size: 28rpx;
}

.image-add {
  flex-direction: column;
  gap: 10rpx;
  border: 2rpx dashed #bbcbba;
  color: #006d33;
  font-size: 24rpx;
  font-weight: 700;
}

.footer-actions {
  position: sticky;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(247, 248, 244, 0), #f7f8f4 24%);
}

.form-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 104rpx;
  margin: 0 -32rpx;
  padding: 28rpx 32rpx 0;
  border-bottom: 1rpx solid #eeeeee;
  background: #f9f9f9;
}

.form-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 58rpx;
  font-weight: 300;
}

.form-title {
  color: #111515;
  font-size: 32rpx;
  font-weight: 900;
}

.cover-upload {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  height: 552rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border: 4rpx dashed #bfd4bf;
  border-radius: 22rpx;
  background: #eeeeee;
  color: #3d4a3d;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

.cover-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  color: #07c160;
  font-size: 48rpx;
  font-weight: 900;
}

.cover-title {
  margin-top: 28rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 800;
}

.cover-sub {
  margin-top: 12rpx;
  color: #6f7d70;
  font-size: 26rpx;
  font-weight: 800;
}

.box-field {
  margin-top: 30rpx;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 8rpx 14rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
}

.optional {
  color: #6f7d70;
  font-weight: 700;
}

.box-input,
.box-picker,
.tag-input-card {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  color: #111515;
  font-size: 28rpx;
  font-weight: 800;
}

.box-picker {
  justify-content: space-between;
}

.picker-pin {
  margin-right: 14rpx;
  color: #007832;
  font-size: 34rpx;
}

.picker-arrow {
  margin-left: auto;
  color: #a8bca9;
  font-size: 34rpx;
}

.tag-input-card {
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 108rpx;
  padding: 20rpx 28rpx;
}

.form-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #007832;
  font-size: 26rpx;
  font-weight: 900;
}

.tag-input {
  flex: 1;
  min-width: 160rpx;
  height: 54rpx;
  font-size: 26rpx;
}

.box-contents-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 54rpx;
}

.contents-title {
  color: #111515;
  font-size: 28rpx;
  font-weight: 900;
}

.contents-count {
  margin-top: 6rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 800;
}

.contents-add {
  color: #007832;
  font-size: 26rpx;
  font-weight: 900;
}

.form-content-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.form-content-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 116rpx;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.form-content-img {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
}

.form-content-main {
  flex: 1;
  min-width: 0;
}

.form-content-title {
  overflow: hidden;
  color: #111515;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-content-meta {
  margin-top: 4rpx;
  color: #6f7d70;
  font-size: 24rpx;
  font-weight: 800;
}

.form-content-delete {
  color: #bfd4bf;
  font-size: 34rpx;
  font-weight: 900;
}

.add-more-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  min-height: 178rpx;
  margin-top: 22rpx;
  border: 4rpx dashed #bfd4bf;
  border-radius: 20rpx;
  color: #bfd4bf;
  font-size: 26rpx;
  font-weight: 900;
}

.add-more-icon {
  margin-bottom: 16rpx;
  font-size: 44rpx;
}

.box-footer {
  position: sticky;
  margin: 58rpx -8rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
