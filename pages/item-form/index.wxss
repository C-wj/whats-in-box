.form-card {
  margin-top: 12rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.34);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.topbar__actions .icon-btn {
  width: 96rpx;
  min-width: 96rpx;
  max-width: 96rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.image-cell,
.image-add {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 190rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 16rpx 36rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.image-cell image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.48);
  color: #ffffff;
  font-size: 28rpx;
}

.image-add {
  flex-direction: column;
  gap: 10rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.7);
  color: #006d33;
  font-size: 24rpx;
  font-weight: 700;
}

.footer-actions {
  position: sticky;
  bottom: 0;
  z-index: 10;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(243, 252, 240, 0), rgba(243, 252, 240, 0.92) 34%);
}

.form-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: 104rpx;
  margin: 0 -32rpx;
  padding: 28rpx 32rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.form-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007832;
  font-size: 58rpx;
  font-weight: 300;
}

.form-title {
  color: #161d16;
  font-size: 32rpx;
  font-weight: 900;
}

.cover-upload {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  height: 552rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border: 3rpx dashed rgba(255, 255, 255, 0.72);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.72), transparent 38%),
    rgba(255, 255, 255, 0.28);
  color: #3d4a3d;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

.cover-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.18);
  color: #07c160;
  font-size: 48rpx;
  font-weight: 900;
}

.cover-title {
  margin-top: 28rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 800;
}

.cover-sub {
  margin-top: 12rpx;
  color: #6f7d70;
  font-size: 26rpx;
  font-weight: 800;
}

.box-field {
  margin-top: 30rpx;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 8rpx 14rpx;
  color: #3d4a3d;
  font-size: 28rpx;
  font-weight: 900;
}

.optional {
  color: #6f7d70;
  font-weight: 700;
}

.box-input,
.box-picker,
.tag-input-card {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 16rpx 34rpx rgba(22, 29, 22, 0.05);
  color: #161d16;
  font-size: 28rpx;
  font-weight: 800;
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.box-picker {
  justify-content: space-between;
}

.picker-pin {
  margin-right: 14rpx;
  color: #007832;
  font-size: 34rpx;
}

.picker-arrow {
  margin-left: auto;
  color: #a8bca9;
  font-size: 34rpx;
}

.tag-input-card {
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 108rpx;
  padding: 20rpx 28rpx;
}

.form-tag {
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.22);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #007832;
  font-size: 26rpx;
  font-weight: 900;
}

.tag-input {
  flex: 1;
  min-width: 160rpx;
  height: 54rpx;
  font-size: 26rpx;
}

.box-contents-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 54rpx;
}

.contents-title {
  color: #161d16;
  font-size: 28rpx;
  font-weight: 900;
}

.contents-count {
  margin-top: 6rpx;
  color: #3d4a3d;
  font-size: 26rpx;
  font-weight: 800;
}

.contents-add {
  color: #007832;
  font-size: 26rpx;
  font-weight: 900;
}

.form-content-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.form-content-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 116rpx;
  padding: 18rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 14rpx 32rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.form-content-img {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
}

.form-content-main {
  flex: 1;
  min-width: 0;
}

.form-content-title {
  overflow: hidden;
  color: #161d16;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-content-meta {
  margin-top: 4rpx;
  color: #6f7d70;
  font-size: 24rpx;
  font-weight: 800;
}

.form-content-delete {
  color: #bfd4bf;
  font-size: 34rpx;
  font-weight: 900;
}

.add-more-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  min-height: 178rpx;
  margin-top: 22rpx;
  border: 3rpx dashed rgba(255, 255, 255, 0.72);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #6c7b6c;
  font-size: 26rpx;
  font-weight: 900;
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.add-more-icon {
  margin-bottom: 16rpx;
  font-size: 44rpx;
}

.box-footer {
  position: sticky;
  margin: 58rpx -8rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
