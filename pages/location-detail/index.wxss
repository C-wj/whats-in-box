.box-detail-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: #f9f9f9;
}

.detail-nav {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 32rpx;
  padding-left: 32rpx;
  color: #111515;
}

.detail-nav__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  font-size: 46rpx;
  font-weight: 300;
}

.detail-nav__title {
  color: #111515;
  font-size: 28rpx;
  font-weight: 500;
}

.box-hero {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}

.box-hero image {
  width: 100%;
  height: 100%;
}

.box-hero__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background:
    radial-gradient(circle at 70% 28%, rgba(7, 193, 96, 0.2), transparent 32%),
    linear-gradient(145deg, #dfe8e4 0%, #9fb0aa 52%, #46514e 100%);
  color: rgba(255, 255, 255, 0.88);
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.box-hero__shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.18), rgba(249, 249, 249, 0) 36%, #f9f9f9 100%);
}

.box-info-card {
  position: relative;
  z-index: 5;
  margin: -96rpx 32rpx 0;
  padding: 30rpx;
  border: 1rpx solid #ededed;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.box-info-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.box-info-title {
  color: #111515;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 50rpx;
}

.box-info-location {
  margin-top: 10rpx;
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 700;
}

.box-edit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 84rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #007832;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 32rpx;
}

.detail-tag {
  padding: 12rpx 22rpx;
  border: 2rpx solid rgba(0, 109, 51, 0.18);
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.08);
  color: #006d33;
  font-size: 22rpx;
  font-weight: 800;
}

.detail-tag:nth-child(1) {
  border-color: rgba(0, 88, 188, 0.18);
  background: rgba(0, 88, 188, 0.08);
  color: #0058bc;
}

.detail-tag:nth-child(2) {
  border-color: rgba(140, 80, 0, 0.18);
  background: rgba(140, 80, 0, 0.08);
  color: #8c5000;
}

.box-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28rpx;
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #eeeeee;
}

.box-metric {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.metric-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f0f1f1;
  color: #006d33;
  font-size: 34rpx;
  font-weight: 900;
}

.metric-icon--blue {
  color: #0058bc;
}

.metric-small {
  color: #3d4a3d;
  font-size: 22rpx;
  font-weight: 800;
}

.metric-big {
  color: #111515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.child-section,
.detail-section,
.history-section {
  margin: 44rpx 32rpx 0;
}

.contents-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.contents-title {
  color: #111515;
  font-size: 32rpx;
  font-weight: 800;
}

.contents-add {
  color: #006d33;
  font-size: 24rpx;
  font-weight: 800;
}

.contents-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-shrink: 0;
}

.contents-withdraw {
  color: #0058bc;
  font-size: 24rpx;
  font-weight: 800;
}

.child-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.child-card {
  min-height: 148rpx;
  padding: 24rpx;
}

.child-card__name {
  color: #1a1c1c;
  font-size: 28rpx;
  font-weight: 800;
}

.child-card__meta {
  margin-top: 12rpx;
  color: #6c7b6c;
  font-size: 24rpx;
}

.detail-item-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 144rpx;
  padding: 20rpx;
  border: 1rpx solid #ededed;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.detail-item__thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: #eeeeee;
  color: #006d33;
  font-size: 34rpx;
  font-weight: 900;
}

.detail-item__thumb image {
  width: 100%;
  height: 100%;
}

.detail-item__copy {
  flex: 1;
  min-width: 0;
}

.detail-item__title {
  overflow: hidden;
  color: #111515;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-item__meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #3d4a3d;
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-item__side {
  color: #006d33;
  font-size: 26rpx;
  font-weight: 800;
  text-align: right;
}

.chevron {
  color: #3d4a3d;
  font-size: 34rpx;
  font-weight: 400;
}

.timeline {
  margin-top: 26rpx;
  padding-left: 18rpx;
  border-left: 4rpx solid #e1e4e1;
}

.timeline-row {
  position: relative;
  padding: 0 0 34rpx 36rpx;
}

.timeline-dot {
  position: absolute;
  top: 8rpx;
  left: -29rpx;
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  background: #d5d9d5;
}

.timeline-row--active .timeline-dot {
  background: #007832;
}

.timeline-date {
  color: #3d4a3d;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.04em;
}

.timeline-copy {
  margin-top: 6rpx;
  color: #111515;
  font-size: 24rpx;
  line-height: 32rpx;
}

.detail-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(52rpx + env(safe-area-inset-bottom));
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: #007832;
  color: #ffffff;
  font-size: 54rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 109, 51, 0.28);
}

.empty-btn {
  margin-top: 28rpx;
}
