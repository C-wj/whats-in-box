.withdraw-page {
  min-height: 100vh;
  padding-bottom: 260rpx;
  background: transparent;
}

.withdraw-topbar {
  position: sticky;
  top: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 30rpx;
  padding-left: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.05);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.withdraw-topbar__btn,
.withdraw-topbar__more {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #007832;
  font-size: 52rpx;
  font-weight: 300;
}

.withdraw-topbar__more {
  color: #3d4a3d;
  font-size: 46rpx;
  font-weight: 800;
}

.withdraw-topbar__title {
  color: #007832;
  font-size: 32rpx;
  font-weight: 500;
}

.withdraw-body {
  padding: 44rpx 32rpx 0;
}

.withdraw-box-card {
  display: flex;
  align-items: center;
  gap: 26rpx;
  min-height: 142rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.9);
  border-left-color: rgba(255, 255, 255, 0.82);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 22rpx 50rpx rgba(22, 29, 22, 0.07);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.withdraw-box-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 26rpx;
  background: rgba(7, 193, 96, 0.16);
  color: #007832;
  font-size: 42rpx;
  font-weight: 900;
}

.withdraw-box-copy {
  flex: 1;
  min-width: 0;
}

.withdraw-box-name {
  overflow: hidden;
  color: #161d16;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.withdraw-box-path {
  margin-top: 6rpx;
  overflow: hidden;
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.withdraw-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 42rpx 0 22rpx;
}

.withdraw-section-title {
  color: #161d16;
  font-size: 34rpx;
  font-weight: 900;
}

.withdraw-section-count {
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 800;
}

.withdraw-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.withdraw-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 154rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-top-color: rgba(255, 255, 255, 0.88);
  border-left-color: rgba(255, 255, 255, 0.78);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: 0 18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.withdraw-check {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #b9cbbb;
  border-radius: 7rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.withdraw-check--active {
  border-color: #007832;
  background: linear-gradient(135deg, #45e17c, #007832);
}

.withdraw-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 32% 20%, rgba(255, 255, 255, 0.78), transparent 44%),
    linear-gradient(135deg, rgba(7, 193, 96, 0.2), rgba(118, 243, 234, 0.18));
  color: #007832;
  font-size: 38rpx;
  font-weight: 900;
}

.withdraw-thumb image {
  width: 100%;
  height: 100%;
}

.withdraw-item-copy {
  flex: 1;
  min-width: 0;
}

.withdraw-item-name {
  overflow: hidden;
  color: #161d16;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.withdraw-item-meta {
  margin-top: 6rpx;
  color: #3d4a3d;
  font-size: 24rpx;
  font-weight: 800;
}

.withdraw-counter {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  height: 66rpx;
  padding: 5rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.56);
}

.counter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #161d16;
  font-size: 32rpx;
  font-weight: 600;
}

.counter-value {
  min-width: 52rpx;
  color: #161d16;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.withdraw-empty {
  margin-top: 24rpx;
}

.withdraw-footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  min-height: calc(236rpx + env(safe-area-inset-bottom));
  padding: 28rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.38);
  background: rgba(255, 255, 255, 0.48);
  box-shadow: 0 -18rpx 42rpx rgba(22, 29, 22, 0.06);
  -webkit-backdrop-filter: blur(30rpx);
  backdrop-filter: blur(30rpx);
}

.withdraw-footer-label {
  color: #3d4a3d;
  font-size: 23rpx;
  font-weight: 800;
}

.withdraw-footer-title {
  margin-top: 6rpx;
  color: #161d16;
  font-size: 34rpx;
  font-weight: 900;
}

.withdraw-clear {
  position: absolute;
  top: 44rpx;
  right: 38rpx;
  color: #0058bc;
  font-size: 24rpx;
  font-weight: 800;
}

.withdraw-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  width: 100%;
  height: 86rpx;
  margin-top: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45e17c, #007832);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 34rpx rgba(7, 193, 96, 0.28);
}

.withdraw-confirm-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid #ffffff;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 34rpx;
}
